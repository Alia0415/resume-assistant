# ============================================================
# 求职管家后端 · 环境变量示例
# 复制本文件为 .env 并填入你自己的 DeepSeek API Key
#   cp .env.example .env
# .env 文件已被 .gitignore 忽略，绝不会提交到仓库，也不会暴露给前端。
# ============================================================

# 你的 DeepSeek API Key（必填）。在 https://platform.deepseek.com 获取。
DEEPSEEK_API_KEY=

# 默认模型。按需求默认使用 deepseek-v4-flash。
DEEPSEEK_MODEL=deepseek-v4-flash

# 复杂的简历深度改写可切换的模型（/api/ai/rewrite-resume 会优先使用它，未配置则回退到 DEEPSEEK_MODEL）。
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# 服务端口（可选，默认 3000）
PORT=3000

# 监听地址（本地可留空；腾讯云配合 Nginx 时建议设为 127.0.0.1）
HOST=

# 登录会话签名密钥（强烈建议生产环境填写一段随机长字符串）。
# 未配置时后端会用进程内临时密钥，重启后所有登录态都会失效。
# 可用以下命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# 是否开放注册（默认 true）。创建好账号后可设为 false 关闭注册入口。
ALLOW_REGISTRATION=true

# ============================================================
# 账号持久化（腾讯云 CloudBase 云托管）
# ------------------------------------------------------------
# 设置 TCB_ENV_ID 为你的 CloudBase「环境 ID」后，账号将保存在云数据库，
# 容器重启 / 重新部署 / 实例切换都不会丢失。
# 留空（本地开发）时回退到 server/data/users.json。
# 在云托管运行时，访问云数据库的临时凭证由平台自动注入，无需填写 SecretId/SecretKey。
TCB_ENV_ID=
# 存放账号的集合名（可选，默认 jm_users）。
TCB_USERS_COLLECTION=jm_users
# 存放用户业务数据（简历 / 岗位 / 匹配 / 投递材料等整份 db）的集合名（可选，默认 jm_user_data）。
TCB_DATA_COLLECTION=jm_user_data
# 存放简历原文件（PDF/DOC/DOCX）元数据的集合名（可选，默认 jm_files）。原文件本体存 CloudBase 云存储。
TCB_FILES_COLLECTION=jm_files
